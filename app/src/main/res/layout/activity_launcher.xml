<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnExitHotspot"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="2dp"
        android:alpha="0.7"
        android:background="@drawable/bg_caregiver_dot"
        android:contentDescription="@string/caregiver_entry_desc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_hotspot" />

    <LinearLayout
        android:id="@+id/toolButtonsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnExitHotspot">

        <Button
            android:id="@+id/btnFlashlight"
            android:layout_width="0dp"
            android:layout_height="82dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tool_flash"
            android:backgroundTint="@null"
            android:drawableStart="@drawable/ic_btn_flashlight"
            android:drawablePadding="10dp"
            android:drawableTint="@android:color/white"
            android:gravity="center"
            android:text="@string/flashlight_on"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCleanDouyin"
            android:layout_width="0dp"
            android:layout_height="82dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tool_trash"
            android:backgroundTint="@null"
            android:drawableStart="@drawable/ic_btn_trash"
            android:drawablePadding="10dp"
            android:drawableTint="@android:color/white"
            android:gravity="center"
            android:text="@string/clean_douyin"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnDouyin"
        android:layout_width="0dp"
        android:layout_height="96dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_douyin_hero"
        android:backgroundTint="@null"
        android:drawableStart="@drawable/ic_btn_douyin"
        android:drawablePadding="12dp"
        android:drawableTint="@android:color/white"
        android:gravity="center"
        android:padding="20dp"
        android:text="@string/douyin"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolButtonsRow" />

    <LinearLayout
        android:id="@+id/timeCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnDouyin">

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/time_placeholder"
            android:textColor="@color/text_primary"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/date_placeholder"
            android:textColor="@color/text_secondary"
            android:textSize="24sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvFamilyTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/family_section_title"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/timeCard" />

    <TextView
        android:id="@+id/tvNoContacts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/no_contacts_hint"
        android:textColor="@color/text_secondary"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFamilyTitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContacts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNoContacts" />

</androidx.constraintlayout.widget.ConstraintLayout>
